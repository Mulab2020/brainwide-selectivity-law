{
    "random_seed": 0,
    "is_control": false,
    
    "out_dir": "outputs/sweeps/test",
    "model_cfg_path": "configs/model.json",
    "dataset_dir": "datasets/",

    "range_alpha": [0.0, 10.35],
    "range_beta": [0.0, 10.35],
    "n_nodes": [23, 23],

    "train": {
        "batch_size": 1000,
        "lr": 1e-3,
        "n_epochs": 500,
        "eval_every_n_epochs": 40,
        "save_every_n_epochs": 50,

        "num_workers_train": 4,
        "num_workers_val": 4
    },

    "fid_eval": {
        "batch_size": 1000,
        "inception_dims": 2048,
        "samples_per_class": 100,
        "num_workers": 4
    },
    
    "device": "cuda"
}
